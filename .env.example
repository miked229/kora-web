# ================================================================
# KORA DJ Booking System — Environment Variables
# ================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ================================================================

# ── Supabase ─────────────────────────────────────────────────────
# Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ───────────────────────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Dashboard → Developers → Webhooks → Add endpoint
# Endpoint URL: https://YOUR_PROJECT_REF.supabase.co/functions/v1/stripe-webhook
# Events to listen: payment_intent.succeeded, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (transactional email) ─────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_...

# ── Deployment ───────────────────────────────────────────────────
# Used in booking-success.html return URL
SITE_URL=https://koramx.com

# ── Notes ────────────────────────────────────────────────────────
# 1. Set SUPABASE_URL, SUPABASE_ANON_KEY in booking.html and
#    booking-success.html (search for YOUR_PROJECT_REF / YOUR_SUPABASE_ANON_KEY).
#
# 2. Set STRIPE_PUBLIC_KEY (pk_live_...) in booking.html and
#    booking-success.html (search for YOUR_STRIPE_PUBLIC_KEY).
#
# 3. Set EVENT_ID in booking.html to the UUID of the May-15 event.
#    Run: SELECT id FROM events WHERE name ILIKE '%KORA%' LIMIT 1;
#
# 4. All server-side secrets (STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET,
#    SUPABASE_SERVICE_ROLE_KEY, RESEND_API_KEY) are set ONLY in
#    Supabase Dashboard → Edge Functions → Secrets. They never touch
#    the browser.
#
# 5. For testing use Stripe test keys (pk_test_..., sk_test_...) and
#    card number 4242 4242 4242 4242, any future date, any CVC.
